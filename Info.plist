<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>BloomBackground</string>
		<key>UIImageName</key>
		<string>AppIcon</string>
		<key>UILaunchStoryboardName</key>
		<string>LaunchScreen</string>
	</dict>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>fetch</string>
		<string>processing</string>
	</array>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.pangtong.bloom.healthDecay</string>
		<string>com.pangtong.bloom.widgetRefresh</string>
	</array>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>NSUbiquitousContainerIsDocumentPackagePublic</key>
	<false/>
	<key>NSUbiquitousContainerAllowedFileExtensions</key>
	<array>
		<string>json</string>
	</array>
	<key>NSUbiquitousContainerName</key>
	<string>iCloud.com.pangtong.bloom</string>
	<key>MinimumOSVersion</key>
	<string>17.0</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
	</dict>
	<key>CFBundleLocalizations</key>
	<array>
		<string>en</string>
		<string>zh_CN</string>
	</array>
	<!--
		HealthKit 权限说明（App Store 审核 5.1.2 合规要求）：
		- NSHealthShareUsageDescription：说明为什么要"读取"健康数据
		- NSHealthUpdateUsageDescription：说明为什么要"写入"健康数据
		两个 key 都必须清晰、诚实地描述数据用途，否则可能被拒审
	-->
	<key>NSHealthShareUsageDescription</key>
	<string>Bloom reads your water intake data from HealthKit to sync records from other apps and help your digital plant grow. We only access dietary water data and never upload it to third-party servers.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>Bloom saves the water you record in the app to HealthKit so your hydration data stays in sync across all your devices. Data is only stored locally and in Apple Health.</string>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.pangtong.bloom</string>
	</array>
</dict>
</plist>
